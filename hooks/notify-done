#!/usr/bin/env bash
# Stop hook — fires when Claude finishes its overall response. Pings a desktop
# notification (Linux only, via notify-send) so you don't have to keep the
# terminal in focus.
#
# Suppresses the notification if the active window IS a known terminal class
# OR an editor that commonly hosts an integrated terminal (VS Code, Cursor,
# JetBrains). Falls through to notifying if focus detection isn't available
# (xdotool/xprop missing, no DISPLAY, Wayland w/o XWayland) — better to
# over-notify than miss the ping.
#
# Implementation note: we use `xdotool getactivewindow` to grab the window
# ID, then `xprop WM_CLASS` to read its class. xdotool's own
# `getwindowclass` / `getwindowclassname` subcommands are absent on some
# distro builds (the older C version) — xprop is universally available
# wherever X11 is, so it's a more portable read.
#
# Wayland note: both tools need X11/XWayland. On Wayland-only setups,
# focus detection silently fails and you'll always get the notification.

set -euo pipefail

should_notify=true

if command -v xdotool >/dev/null 2>&1 && command -v xprop >/dev/null 2>&1 && [ -n "${DISPLAY:-}" ]; then
    win_id=$(xdotool getactivewindow 2>/dev/null || echo "")
    active_class=""
    if [ -n "$win_id" ]; then
        # WM_CLASS(STRING) = "instance", "Class" — take the last quoted token (the class).
        active_class=$(xprop -id "$win_id" WM_CLASS 2>/dev/null | sed -n 's/.*"\([^"]*\)"$/\1/p')
    fi
    case "$active_class" in
        # Terminal emulators
        Gnome-terminal|gnome-terminal|kitty|Kitty|Alacritty|alacritty|Konsole|konsole|XTerm|xterm|UXTerm|st|St|Terminator|terminator|Tilix|tilix|WezTerm|wezterm|Foot|foot|Ghostty|ghostty|Hyper|hyper)
            should_notify=false
            ;;
        # Editors with integrated terminals (you're probably already watching the output)
        Code|code|Code-Insiders|code-insiders|VSCodium|vscodium|Cursor|cursor|Windsurf|windsurf|jetbrains-idea|jetbrains-pycharm|jetbrains-webstorm|jetbrains-goland|jetbrains-rider|jetbrains-clion|jetbrains-rubymine|jetbrains-phpstorm)
            should_notify=false
            ;;
    esac
fi

if [ "$should_notify" = "true" ] && command -v notify-send >/dev/null 2>&1; then
    notify-send "Claude Code" "done" --urgency=low --expire-time=3000 2>/dev/null || true
fi

exit 0
